<div class="card">
  <h2>Conciliação Bancária</h2>
  <p class="subtitle">Algoritmo de Casamento Exato (Data + Valor ±R$ 0,01)</p>

  <% if flash[:error] %>
    <div class="alert alert-error"><%= flash[:error] %></div>
  <% end %>

  <%= form_with url: upload_path, multipart: true, local: true do |f| %>
    <div class="form-group">
      <label>Extrato Bancário (.xls ou .xlsx)</label>
      <%= f.file_field :banco_file, accept: ".xls,.xlsx", required: true %>
    </div>

    <div class="form-group">
      <label>Lançamentos ERP (.xls ou .xlsx)</label>
      <%= f.file_field :erp_file, accept: ".xls,.xlsx", required: true %>
    </div>

    <div class="form-actions">
      <%= f.submit "Avançar →", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
